{
  "name": "@ostanlabs/canvas-project-manager",
  "version": "1.8.95",
  "description": "Visual project management on Obsidian Canvas - manage milestones, stories, tasks, decisions, documents, and features with dependencies and Notion sync",
  "main": "main.js",
  "files": [
    "main.js",
    "main.ts",
    "manifest.json",
    "styles.css",
    "types.ts",
    "settings.ts",
    "notion/",
    "ui/",
    "util/"
  ],
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "npm run build:plugin && npm run build:mcp",
    "build:plugin": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
    "build:mcp": "esbuild mcp.ts --bundle --outfile=bin/mcp-server.mjs --platform=node --format=esm --loader:.html=text --external:@modelcontextprotocol/sdk --external:@ostanlabs/md-retriever --external:onnxruntime-node --external:@xenova/transformers --external:better-sqlite3 --external:faiss-node --external:yaml --external:chokidar",
    "dev:mcp": "tsx watch mcp.ts",
    "typecheck": "tsc -noEmit -skipLibCheck",
    "version": "node version-bump.mjs && git add manifest.json versions.json",
    "test": "jest",
    "test:core": "vitest run",
    "test:core:watch": "vitest",
    "test:watch": "jest --watch",
    "test:integration": "jest --config jest.config.integration.js",
    "test:mcp": "jest --config jest.config.integration.js tests/integration/mcp-stdio.test.ts",
    "coverage:mcp": "node scripts/coverage-mcp.mjs",
    "test:all": "npm run test:core && npm run test && npm run test:integration",
    "lint": "eslint . --ext .ts",
    "format": "prettier --write \"**/*.{ts,tsx,json,md}\""
  },
  "keywords": [
    "obsidian",
    "plugin",
    "canvas",
    "notion",
    "accomplishments",
    "project-management",
    "workflow"
  ],
  "author": "Ostan Labs",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ostanlabs/obsidian_plugin.git"
  },
  "engines": {
    "node": ">=22"
  },
  "devDependencies": {
    "@eslint/json": "^0.14.0",
    "@types/jest": "^29.5.12",
    "@types/node": "^24.0.0",
    "@typescript-eslint/parser": "^8.50.0",
    "@vitest/coverage-v8": "^3.2.6",
    "builtin-modules": "^3.3.0",
    "c8": "^11.0.0",
    "esbuild": "^0.20.1",
    "eslint": "^9.39.2",
    "eslint-plugin-obsidianmd": "^0.1.9",
    "jest": "^29.7.0",
    "obsidian": "latest",
    "prettier": "^3.2.5",
    "ts-jest": "^29.1.2",
    "tslib": "^2.6.2",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "typescript-eslint": "^8.50.0",
    "vitest": "^3.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^0.5.0",
    "@notionhq/client": "^2.2.15",
    "@ostanlabs/md-retriever": "^0.2.0",
    "yaml": "^2.3.4"
  }
}
